# Copy this file to .env and fill in your own Supabase project values.
# Find these under Project Settings > API in the Supabase dashboard.
# Safe to expose client-side — access is controlled by Row Level Security, not key secrecy.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
